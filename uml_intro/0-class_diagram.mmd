classDiagram
    class Library {
        +add_book()
        +register_user()
        +create_loan()
    }

    class Book {
        +str title
        +str author
        +bool available
        +mark_as_unavailable()
        +mark_as_available()
    }

    class User {
        +str name
        +str email
    }

    class Loan {
        +str start_date
        +str end_date
        +close_loan()
    }

    %% Relations et Multiplicités
    Library "1" *-- "*" Book : manages
    Library "1" *-- "*" User : manages
    Library "1" --> "*" Loan : creates

    User "1" -- "0..*" Loan : has
    Book "1" -- "0..*" Loan : involved in
